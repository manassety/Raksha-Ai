rules_version = '2';

// Firebase Storage Rules for RakshaAi
service firebase.storage {
  match /b/{bucket}/o {
    
    // Give authenticated users permission to read and write to the evidence folder
    match /evidence/{allPaths=**} {
      allow read, write: if request.auth != null; 
    }
    
    // Allow access to other paths for authenticated users as well
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
